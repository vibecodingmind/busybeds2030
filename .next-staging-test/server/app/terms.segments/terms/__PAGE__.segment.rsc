0:{"rsc":["$","$1","c",{"children":[["$","div",null,{"className":"min-h-screen bg-gradient-to-br from-slate-900 via-blue-950 to-slate-900","children":["$","div",null,{"className":"max-w-4xl mx-auto px-4 py-16","children":[["$","h1",null,{"className":"text-4xl font-bold text-white mb-8","children":"Terms of Service"}],["$","div",null,{"className":"prose prose-invert max-w-none space-y-6 text-blue-100","children":[["$","p",null,{"className":"text-sm text-blue-300","children":"Last updated: June 2026"}],["$","h2",null,{"className":"text-2xl font-semibold text-white","children":"1. Acceptance of Terms"}],["$","p",null,{"children":"By accessing or using BusyBeds, you agree to be bound by these Terms of Service. If you do not agree, please do not use our services."}],["$","h2",null,{"className":"text-2xl font-semibold text-white","children":"2. Membership & Subscriptions"}],["$","p",null,{"children":"BusyBeds operates on a monthly subscription model. Members receive digital discount coupons that can be used at partner hotels. Subscriptions auto-renew monthly unless cancelled. Coupon credits do not roll over between billing periods."}],["$","h2",null,{"className":"text-2xl font-semibold text-white","children":"3. Coupon Usage"}],["$","p",null,{"children":"Coupons are digital vouchers that provide verified discounts at partner hotels. Each coupon is assigned to a specific hotel and is valid for the stated discount percentage. Coupons must be presented to hotel staff for verification via the QR code. Hotels verify coupons through our secure portal."}],["$","h2",null,{"className":"text-2xl font-semibold text-white","children":"4. Payment & Refunds"}],["$","p",null,{"children":"Subscription payments are processed through PesaPal. All payments are non-refundable once the subscription period begins. Hotel deposits are paid directly to the hotel and are subject to the hotel's own cancellation and refund policies."}],["$","h2",null,{"className":"text-2xl font-semibold text-white","children":"5. No-Show Policy"}],["$","p",null,{"children":"If a member fails to check in at a hotel after a coupon has been confirmed, the hotel may retain the deposit as per their policy. The coupon credit will still be deducted from the member's account."}],["$","h2",null,{"className":"text-2xl font-semibold text-white","children":"6. User Conduct"}],["$","p",null,{"children":"Users must not attempt to duplicate, resell, or transfer coupons to non-members. Fraudulent use of coupons may result in immediate account termination without refund."}],["$","h2",null,{"className":"text-2xl font-semibold text-white","children":"7. Limitation of Liability"}],["$","p",null,{"children":"BusyBeds acts as a discount facilitator and does not guarantee hotel availability, quality of service, or specific room types. Disputes with hotels should be resolved directly with the hotel."}],["$","h2",null,{"className":"text-2xl font-semibold text-white","children":"8. Contact"}],["$","p",null,{"children":"For questions about these terms, contact us at legal@busybeds.com."}]]}]]}]}],null,["$","$L2",null,{"children":["$","$3",null,{"name":"Next.MetadataOutlet","children":"$@4"}]}]]}],"isPartial":false,"staleTime":300,"varyParams":null,"buildId":"kizZ8et2PZd6klhINstOC"}
