{
  "headers": {
    "x-nextjs-stale-time": "300",
    "x-nextjs-prerender": "1",
    "x-next-cache-tags": "_N_T_/layout,_N_T_/hotel/layout,_N_T_/hotel/dashboard/layout,_N_T_/hotel/dashboard/page,_N_T_/hotel/dashboard"
  },
  "segmentPaths": [
    "/_tree",
    "/_full",
    "/hotel/dashboard/__PAGE__",
    "/hotel/dashboard",
    "/hotel",
    "/_index",
    "/_head"
  ]
}